# SicBox Engine – Runtime configuration
# Copy this file and fill in real values before running docker-compose up.

# Minimum 32 characters. Generate with:  openssl rand -hex 32
ADMIN_TOKEN=change_this_to_a_strong_random_secret_at_least_32_chars

# RocksDB ledger path (inside the container)
DATABASE_PATH=/app/data/ledger

# Unix socket path shared with Nginx (must match proxy_seguro.conf)
SOCKET_PATH=/var/run/app/engine.sock

# Monero Wallet RPC endpoint.
# If monerod + monero-wallet-rpc run on the host machine, use:
#   http://host.docker.internal:18083/json_rpc
# For a pruned local node append: --prune-blockchain to monerod
MONERO_RPC_URL=http://host.docker.internal:18083/json_rpc
